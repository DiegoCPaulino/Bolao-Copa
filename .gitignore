# Dependências
node_modules/

# Build / artefatos de compilação
dist/
build/
*.tsbuildinfo
# Front copiado pra dentro do back no buildCommand do Render (same-origin) — artefato.
backend/public/

# Cobertura de testes
coverage/

# Variáveis de ambiente / segredos — NUNCA versionar.
