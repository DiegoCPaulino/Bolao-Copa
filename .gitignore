*.sqlite
*.sqlite3
*.db

# Dumps de backup (podem conter dados reais — nunca versionar)
backups/

# Logs
*.log
npm-debug.log*

# Sistema operacional
Thumbs.db
.DS_Store

# Editores
.idea/
