# Template (VERSIONADO) das variáveis do backend — SEM segredos reais.
# DEV: copie para backend/.env e ajuste. PROD (Render): defina-as no painel do
# serviço (nunca comite valores). O backend/.env nunca é versionado.
#
# Vars que o Render precisa: DATABASE_URL, NODE_ENV=production, SESSION_SECRET,
# ORGANIZADOR_SENHA_HASH. A PORT é INJETADA pelo Render — não defina à mão lá.

# --- Banco ---
# DEV: casa com o Postgres do docker-compose.yml (raiz).
# PROD: connection string do Postgres gerenciado (ex.: Neon/Render), com sslmode.
DATABASE_URL="postgresql://USUARIO:SENHA@localhost:5432/BANCO?schema=public"

# --- HTTP / ambiente (validadas no boot por config/env.ts; faltando uma, ABORTA) ---
NODE_ENV="development"     # PROD: "production" (liga o cookie Secure; exige HTTPS)
PORT="3000"               # DEV: default 3000. PROD: o Render injeta — não defina aqui.
# Origem do front liberada pelo CORS (Fase 7). DEV: Vite em 5173. PROD: a URL do front.
FRONTEND_ORIGIN="http://localhost:5173"

# --- Auth single-user ---
# SESSION_SECRET: segredo da sessão (cookie httpOnly), >= 32 chars. Gere aleatório:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
SESSION_SECRET="troque-por-um-segredo-aleatorio-de-32-mais-caracteres"
# ORGANIZADOR_SENHA_HASH: hash argon2id da SUA senha (npm run gerar-hash). Só o hash —
# a senha em texto nunca fica no .env.
ORGANIZADOR_SENHA_HASH="$argon2id$v=19$m=65536,t=3,p=4$...cole-o-seu-hash-aqui..."
