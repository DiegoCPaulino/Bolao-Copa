# Template (VERSIONADO) das variáveis do backend — sem segredos reais.
# Copie para backend/.env e ajuste os valores. O backend/.env nunca é versionado.
#
# DATABASE_URL: deve casar com POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB do
# docker-compose.yml (raiz). Formato: postgresql://USUARIO:SENHA@HOST:PORTA/BANCO?schema=public
DATABASE_URL="postgresql://USUARIO:SENHA@localhost:5432/BANCO?schema=public"

# Próximas variáveis chegam na Fase 4 (HTTP + auth), validadas no boot com Zod:
# SESSION_SECRET="..."   # segredo da sessão (cookie httpOnly)
# PORT="3000"            # porta do servidor Fastify
